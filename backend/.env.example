YOUTUBE_API_KEY=your_youtube_data_api_v3_key_here
OPENAI_API_KEY=your_openai_api_key_here
GROQ_API_KEY=your_groq_api_key_here

# Docker services (defaults work with docker-compose.yml in project root)
REDIS_URL=redis://localhost:6379
QDRANT_HOST=localhost
QDRANT_PORT=6333

# Instagram Credentials (optional, for Instagram Reel ingestion)
INSTAGRAM_USERNAME=your_instagram_username_here
INSTAGRAM_PASSWORD=your_instagram_password_here
